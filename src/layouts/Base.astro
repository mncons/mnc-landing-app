---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MNC Consultoría · MNconsultor.IA",
  description = "IA aplicada y ERP Odoo para MiPyMEs colombianas. Diagnóstico en 48 horas. Resultados medibles en 30 días.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/brand/logo/favicon.svg" />
    <link rel="icon" type="image/png" href="/brand/logo/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/brand/logo/favicon-16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/brand/logo/apple-touch-icon.png" />

    <link
      rel="preload"
      href="/brand/fonts/din-2014-narrow-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/brand/fonts/din-2014-narrow-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
  </body>
</html>
